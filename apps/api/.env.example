# Copy this file to `.env` and fill in real values. Never commit `.env`.

# The Odds API v4 key (https://the-odds-api.com/). Used by app/ingestion/odds_client.py.
# Free/paid tiers are credit-based; the MVP budget assumes the ~20K credits tier.
ODDS_API_KEY=

# SQLAlchemy database URL (Postgres with the psycopg 3 driver).
# Example: postgresql+psycopg://edge:edge@localhost:5432/edge
DATABASE_URL=postgresql+psycopg://edge:edge@localhost:5432/edge

# API key for the LLM research/explanation layer. The LLM never produces
# probabilities; it only summarizes context and drafts pick explanations.
LLM_API_KEY=
